{
  "name": "jtdal",
  "description": "Small template engine based on Zope TAL, using data attributes",
  "exports": "./jTDAL.min.js",
  "types": "jTDAL.d.ts",
  "files": [
    "jTDAL.js",
    "jTDAL.min.js",
    "jTDAL.d.ts",
    "jTDAL.ts",
    "jTDAL.test.js",
    "jTDAL.test.ts",
    "build.mjs",
    "tsconfig.json",
    "tsconfig.tests.json",
    "jsdom.d.ts"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/StefanoBalocco/jTDAL.git"
  },
  "version": "5.0.3",
  "keywords": [
    "template engine",
    "tal"
  ],
  "author": "Stefano Balocco <stefano.balocco@gmail.com>",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/StefanoBalocco/jTDAL/issues"
  },
  "homepage": "https://github.com/StefanoBalocco/jTDAL",
  "scripts": {
    "build": "npm run build:library && npm run build:tests",
    "build:library": "node_modules/typescript/bin/tsc && node_modules/terser/bin/terser jTDAL.js -o jTDAL.min.js --toplevel -m -c --mangle-props regex=/^_/",
    "build:tests": "node_modules/typescript/bin/tsc -p tsconfig.tests.json",
    "tests": "npx ava *.test.js --verbose"
  },
  "devDependencies": {
    "ava": "~6",
    "c8": "~10",
    "terser": "~5",
    "typescript": "~5"
  }
}
